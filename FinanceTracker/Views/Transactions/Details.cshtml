@model FinanceTracker.Models.Transaction

@{
    ViewData["Title"] = "Transaction Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Transaction Details</h4>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th class="col-4">Date</th>
                        <td>@Model.Date.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <th>Amount</th>
                        <td>
                            @if (Model.Category.Type == "Income")
                            {
                                <span class="text-success fw-bold">+ €@Model.Amount.ToString("0.00")</span>
                            }
                            else if (Model.Category.Type == "Savings")
                            {
                                <span class="text-primary fw-bold">~ €@Model.Amount.ToString("0.00")</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">- €@Model.Amount.ToString("0.00")</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Category</th>
                        <td>
                            @if (Model.Category.Type == "Income")
                            {
                                <span class="badge bg-success">@Model.Category.Name</span>
                            }
                            else if (Model.Category.Type == "Savings")
                            {
                                <span class="badge bg-primary">@Model.Category.Name</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@Model.Category.Name</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>User</th>
                        <td>@Model.User.Email</td>
                    </tr>
                </table>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <a asp-action="Edit" asp-route-id="@Model.TransactionId" class="btn btn-primary">Edit</a>
            </div>
        </div>
    </div>
</div>