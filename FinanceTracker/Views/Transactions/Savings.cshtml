
@model IEnumerable<FinanceTracker.Models.Transaction>

@{
    ViewData["Title"] = "My Savings";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2>My Savings</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to Overview</a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h6 class="card-title">Total Saved</h6>
                <h4 class="card-text">€@ViewBag.TotalSavings.ToString("0.00")</h4>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No savings transactions yet!</div>
}
else
{
    <table class="table table-hover table-bordered align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.Description</td>
                    <td><span class="text-primary fw-bold">~ €@item.Amount.ToString("0.00")</span></td>
                    <td><span class="badge bg-primary">@item.Category.Name</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}