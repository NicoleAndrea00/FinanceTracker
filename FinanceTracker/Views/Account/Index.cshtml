@model FinanceTracker.Models.User

@{
    ViewData["Title"] = "My Account";
}

@if (ViewBag.Success != null)
{
    <div class="alert alert-success">@ViewBag.Success</div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Account Details</h4>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th class="col-4">Name</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>@Model.Email</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Change Password</h4>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div class="form-group">
                        <label>Current Password</label>
                        <div class="input-group">
                            <input type="password" name="currentPassword" id="currentPassword" class="form-control" required />
                            <span class="input-group-text" id="toggleBtn1" onclick="togglePassword('currentPassword', 'toggleBtn1')" style="cursor: pointer;">Show</span>
                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <label>New Password</label>
                        <div class="input-group">
                            <input type="password" name="newPassword" id="newPassword" class="form-control" required />
                            <span class="input-group-text" id="toggleBtn2" onclick="togglePassword('newPassword', 'toggleBtn2')" style="cursor: pointer;">Show</span>
                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <label>Confirm New Password</label>
                        <div class="input-group">
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" required />
                            <span class="input-group-text" id="toggleBtn3" onclick="togglePassword('confirmPassword', 'toggleBtn3')" style="cursor: pointer;">Show</span>
                        </div>
                    </div>
                    <div class="form-group mt-3">
                        <input type="submit" value="Change Password" class="btn btn-primary w-100" />
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function togglePassword(inputId, btnId) {
        var input = document.getElementById(inputId);
        var btn = document.getElementById(btnId);
        if (input.type === "password") {
            input.type = "text";
            btn.textContent = "Hide";
        } else {
            input.type = "password";
            btn.textContent = "Show";
        }
    }
</script>