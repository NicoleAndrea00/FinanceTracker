@{
    ViewData["Title"] = "Login";
}

<h2>Login</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="row">
    <div class="col-md-4">
        <form asp-action="Login" method="post">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="form-group mt-2">
                <label>Password</label>
                <div class="input-group">
                    <input type="password" name="password" id="password" class="form-control" required />
                    <span class="input-group-text" id="toggleBtn" onclick="togglePassword()" style="cursor: pointer;">Show</span>
                </div>
            <div class="form-group mt-3">
                <input type="submit" value="Login" class="btn btn-primary" />
            </div>
        </form>
        <p class="mt-2">Don't have an account? <a asp-action="Register">Register here</a></p>
    </div>
</div>
<script>
    function togglePassword() {
        var input = document.getElementById("password");
        var span = document.getElementById("toggleBtn");
        if (input.type === "password") {
            input.type = "text";
            span.textContent = "Hide";
        } else {
            input.type = "password";
            span.textContent = "Show";
        }
    }
</script>